# =====================================================================
# Microsoft Fabric demo - configuration
# Copy this file to ".env" and fill in your own values, then run:
#   pwsh module-0-setup/setup.ps1 -Action infra
# Everything (scripts + docs) keys off these names.
# =====================================================================

# ---- Azure ----------------------------------------------------------
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
RESOURCE_GROUP=rg-fabric-demo
# Pick a region that has all (incl. preview) Fabric features for your tenant.
REGION=uaenorth

# ---- Fabric capacity ------------------------------------------------
# CAPACITY_NAME must be globally unique, lowercase letters/numbers, start with a letter.
CAPACITY_NAME=ntwfabricdemo
CAPACITY_SKU=F4
# UPN of the capacity admin (usually you). Leave blank to use the signed-in az user.
CAPACITY_ADMIN_UPN=

# ---- Fabric workspaces ----------------------------------------------
WORKSPACE_NAME=Fabric-Demo-Workshop
TEST_WORKSPACE_NAME=Fabric-Demo-Workshop-Test

# ---- Item names (created by each module's run.ps1 or in the UI) ------------
LAKEHOUSE_NAME=lh_retail
WAREHOUSE_NAME=wh_retail
SQLDB_NAME=sqldb_orders
EVENTHOUSE_NAME=eh_telemetry
PIPELINE_NAME=pl_ingest

# ---- Notebook config (used inside the Spark notebooks) --------------
BRONZE_SCHEMA=bronze
SILVER_SCHEMA=silver
GOLD_SCHEMA=gold
BRONZE_FILES_PATH=Files/bronze

# ---- Azure Blob Storage (raw landing = external source for the Copy job / Task flow demo) ----
# STORAGE_ACCOUNT_NAME: 3-24 lowercase letters/numbers, globally unique.
STORAGE_ACCOUNT_NAME=ntwfabricdemostg
STORAGE_CONTAINER=retail-raw
STORAGE_RAW_PREFIX=bronze

# ---- Fabric connection + Copy job (Blob -> Lakehouse) --------------
# BLOB_CONNECTION_ID auto-filled by: setup.ps1 -Action connection (or create it in the UI).
BLOB_CONNECTION_ID=
COPYJOB_NAME=cj_blob_to_bronze

# ---- Event Hubs (Module 5 streaming source) ------------------------
# EVENTHUB_NAMESPACE must be globally unique. EVENTHUB_CONNECTION_STRING auto-filled by -Action eventhub.
EVENTHUB_NAMESPACE=ntwfabricdemoeh
EVENTHUB_NAME=telemetry
EVENTHUB_CONNECTION_STRING=

# ---- Resolved IDs (auto-filled by setup.ps1 - leave blank) ----------
WORKSPACE_ID=
TEST_WORKSPACE_ID=
FABRIC_CAPACITY_ID=
LAKEHOUSE_ID=
WAREHOUSE_ID=
SQLDB_ID=
EVENTHOUSE_ID=
KQLDB_ID=

# ---- Workspace identity (provisioned separately; used by Trusted Workspace Access / MPE) ----
WORKSPACE_IDENTITY_APP_ID=
WORKSPACE_IDENTITY_SP_ID=
